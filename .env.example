# =============================================================================
# Database — PostgreSQL (Neon / Supabase / Vercel Postgres / Railway)
# =============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/bahia?schema=public"

# =============================================================================
# Site
# =============================================================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# =============================================================================
# Authentication (admin staff)
# =============================================================================
# Generate with:  openssl rand -base64 48
AUTH_SECRET=""

# Bootstrap admin user — read once by `npm run db:seed`.
# Delete / change in prod after seeding.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Bahia Manager"

# =============================================================================
# Storage — Vercel Blob (production)
# Leave empty in dev → files persisted to .uploads/ on disk.
# =============================================================================
BLOB_READ_WRITE_TOKEN=""

# =============================================================================
# Wave Money (business)
# =============================================================================
NEXT_PUBLIC_WAVE_NUMBER="+225 07 00 00 00 00"
NEXT_PUBLIC_WAVE_MERCHANT_NAME="BAHIA HOTEL — ASSINIE"
# Optional: HTTPS URL to your Wave QR image, replaces the placeholder
NEXT_PUBLIC_WAVE_QR_URL=""

# =============================================================================
# Email — Resend (transactional)
# Sign up: resend.com  ·  Verify your domain to use a custom From
# =============================================================================
RESEND_API_KEY=""
EMAIL_FROM="Bahia <reservations@bahia-assinie.ci>"
# Where staff notifications land (new booking, Wave to verify)
STAFF_EMAIL="reservations@bahia-assinie.ci"

# =============================================================================
# SMS — Orange Côte d'Ivoire (transactional, sent on booking confirmation)
# Provisioning: https://developer.orange.com/apis/sms-ci/
# Without these set, SMS calls log to console (dev mode).
# =============================================================================
ORANGE_SMS_CLIENT_ID=""
ORANGE_SMS_CLIENT_SECRET=""
ORANGE_SMS_SENDER="tel:+22507XXXXXXXX"

# =============================================================================
# Rate limiting — Upstash Redis (REST)
# Sign up: upstash.com  → create Redis DB → copy REST URL + token.
# Without these set, rate limiting is disabled (dev mode).
# =============================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =============================================================================
# Observability — Sentry
# Set DSN to enable. Optional org/project for source map upload at build.
# =============================================================================
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
