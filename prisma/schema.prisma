// Bahia Hotel — Prisma schema
// Production target: PostgreSQL (Neon, Supabase, Vercel Postgres, Railway).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------------------------
// Enums
// --------------------------------------------------------------------------

enum RoomType {
  VILLA
  ROOM
}

enum BookingStatus {
  PENDING_PAYMENT        // ref generated, waiting for guest to pay via Wave
  AWAITING_VERIFICATION  // guest submitted Wave reference, staff verifies
  CONFIRMED              // payment verified — booking active
  CANCELLED
}

enum IdType {
  CNI               // Carte Nationale d'Identité
  PASSPORT
  CONSULAR_CARD     // Carte consulaire / attestation
  RESIDENCE_PERMIT  // Carte de séjour
}

enum PaymentMethod {
  WAVE
  CASH_ON_ARRIVAL
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum KaraokeStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// --------------------------------------------------------------------------
// Users
// --------------------------------------------------------------------------

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  fullName    String
  phone       String
  nationality String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bookings            Booking[]
  identifications     Identification[]
  karaokeReservations KaraokeReservation[]
}

enum AdminRole {
  STAFF
  MANAGER
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  fullName     String
  passwordHash String
  role         AdminRole @default(STAFF)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// --------------------------------------------------------------------------
// Inventory
// --------------------------------------------------------------------------

model Room {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  type          RoomType
  tagline       String
  description   String
  pricePerNight Int       // XOF, integer (no centimes)
  capacity      Int
  surfaceSqm    Int
  imageUrl      String
  amenities     String[]
  totalUnits    Int       @default(1)  // number of identical physical units of this category
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings Booking[]

  @@index([type, isActive])
}

// --------------------------------------------------------------------------
// Bookings
// --------------------------------------------------------------------------

model Booking {
  id        String        @id @default(cuid())
  reference String        @unique      // human-friendly: BHA-XXXXXXXX
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  roomId    String
  room      Room          @relation(fields: [roomId], references: [id])

  checkIn   DateTime  @db.Date
  checkOut  DateTime  @db.Date
  nights    Int
  guests    Int

  // Pricing breakdown — XOF, integers
  subtotalXof Int @default(0)   // nights × pricePerNight (HT)
  vatXof      Int @default(0)   // TVA 18 % CI
  cityTaxXof  Int @default(0)   // Taxe de séjour
  totalXof    Int               // subtotal + vat + cityTax

  status    BookingStatus @default(PENDING_PAYMENT)
  notes     String?

  identification Identification?
  payment        Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([roomId, checkIn, checkOut])
  @@index([status])
}

// --------------------------------------------------------------------------
// Ivorian KYC compliance (Direction de la Surveillance du Territoire)
// --------------------------------------------------------------------------

model Identification {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  fullName     String   // as printed on the ID document
  idType       IdType
  idNumber     String
  imageUrl     String   // recto (front) — signed Vercel Blob URL or local key
  imageKey     String?  // recto storage key
  imageBackUrl String?  // verso (back) — required for CNI / Carte de séjour
  imageBackKey String?  // verso storage key

  rgpdAccepted Boolean  @default(false)
  acceptedAt   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

// --------------------------------------------------------------------------
// Payments
// --------------------------------------------------------------------------

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  method        PaymentMethod @default(WAVE)
  amountXof     Int
  waveReference String?       // user-submitted Wave transaction ID
  status        PaymentStatus @default(PENDING)
  submittedAt   DateTime?
  verifiedAt    DateTime?
  rejectedAt    DateTime?
  rejectReason  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

// --------------------------------------------------------------------------
// Saturday Night Karaoke — table reservations
// --------------------------------------------------------------------------

// --------------------------------------------------------------------------
// Key-value runtime settings — editable from /admin/settings without redeploy
// --------------------------------------------------------------------------

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model KaraokeReservation {
  id        String        @id @default(cuid())
  reference String        @unique
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])

  fullName  String
  phone     String
  email     String?
  date      DateTime      @db.Date  // a Saturday night
  partySize Int
  notes     String?

  status    KaraokeStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([date])
}
